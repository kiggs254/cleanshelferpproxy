# Copy into Coolify → Environment Variables (do NOT commit a populated .env).
# The real ERP host/IP lives ONLY in Coolify env — never commit it here.

# Required — full scheme+host+port of the real ERP. No trailing slash.
ERP_UPSTREAM=http://erp-host.internal:PORT

# Optional — lock the proxy to specific source CIDRs. Comma-separated.
# Leave empty to allow any source (Coolify/Traefik still in front).
# ALLOW_CIDRS=1.2.3.4/32,10.0.0.0/8

# Optional overrides — defaults are usually fine.
# PROXY_SERVER_NAME=_
# PROXY_CLIENT_MAX_BODY_SIZE=10m
# PROXY_CONNECT_TIMEOUT=10s
# PROXY_READ_TIMEOUT=60s
# PROXY_SEND_TIMEOUT=60s
